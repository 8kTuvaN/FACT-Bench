{
  "domain": "finance",
  "version": "1.0.0",
  "description": "Finance domain slot ontology for FACT-Bench. 22 slots across 8 semantic groups. Each slot supports ADD/MODIFY/DELETE/KEEP/CASCADE operation labeling (serves C1); semantic groups enable multi-slot CASCADE detection (serves C2); slots are the atomic building blocks for template synthesis (serves C5).",
  "slot_count": 22,
  "semantic_group_count": 8,
  "slots": {
    "card_last_four": {
      "name": "card_last_four",
      "type": "string",
      "semantic_group": "card_identity",
      "description": "Last four digits of the credit card number.",
      "validation": {"regex": "^\\d{4}$"},
      "enum": null,
      "default": null,
      "example": "4821"
    },
    "card_type": {
      "name": "card_type",
      "type": "enum",
      "semantic_group": "card_identity",
      "description": "Tier/product class of the credit card.",
      "validation": {"enum": ["Standard", "Gold", "Platinum"]},
      "enum": ["Standard", "Gold", "Platinum"],
      "default": "Standard",
      "example": "Gold"
    },
    "card_holder_name": {
      "name": "card_holder_name",
      "type": "string",
      "semantic_group": "card_identity",
      "description": "Full legal name of the cardholder.",
      "validation": {"regex": "^[A-Za-z][A-Za-z .'-]{1,60}$"},
      "enum": null,
      "default": null,
      "example": "Jordan A. Rivera"
    },
    "bill_amount": {
      "name": "bill_amount",
      "type": "float",
      "semantic_group": "bill_info",
      "description": "Current statement balance / bill amount due.",
      "validation": {"min": 0.0, "max": 1000000.0},
      "enum": null,
      "default": null,
      "example": 1284.57
    },
    "due_date": {
      "name": "due_date",
      "type": "date",
      "semantic_group": "bill_info",
      "description": "Payment due date for the current statement.",
      "validation": {"format": "YYYY-MM-DD", "regex": "^\\d{4}-\\d{2}-\\d{2}$"},
      "enum": null,
      "default": null,
      "example": "2026-08-15"
    },
    "minimum_payment": {
      "name": "minimum_payment",
      "type": "float",
      "semantic_group": "bill_info",
      "description": "Minimum payment required to avoid delinquency.",
      "validation": {"min": 0.0, "max": 1000000.0},
      "enum": null,
      "default": null,
      "example": 35.0
    },
    "autopay": {
      "name": "autopay",
      "type": "enum",
      "semantic_group": "autopay_config",
      "description": "Whether autopay is currently enabled for the card.",
      "validation": {"enum": ["enabled", "disabled"]},
      "enum": ["enabled", "disabled"],
      "default": "disabled",
      "example": "enabled"
    },
    "autopay_bank": {
      "name": "autopay_bank",
      "type": "string",
      "semantic_group": "autopay_config",
      "description": "Name of the funding bank account used for autopay.",
      "validation": {"regex": "^[A-Za-z0-9 .&'-]{2,60}$"},
      "enum": null,
      "default": null,
      "example": "First National Bank"
    },
    "autopay_date": {
      "name": "autopay_date",
      "type": "string",
      "semantic_group": "autopay_config",
      "description": "Day of month (1-28) on which autopay is scheduled to run.",
      "validation": {"regex": "^([1-9]|1[0-9]|2[0-8])$"},
      "enum": null,
      "default": null,
      "example": "15"
    },
    "credit_limit": {
      "name": "credit_limit",
      "type": "integer",
      "semantic_group": "credit_config",
      "description": "Permanent credit limit on the card.",
      "validation": {"min": 0, "max": 1000000},
      "enum": null,
      "default": null,
      "example": 8000
    },
    "temp_limit": {
      "name": "temp_limit",
      "type": "integer",
      "semantic_group": "credit_config",
      "description": "Temporary credit limit increase currently in effect.",
      "validation": {"min": 0, "max": 1000000},
      "enum": null,
      "default": null,
      "example": 12000
    },
    "phone": {
      "name": "phone",
      "type": "string",
      "semantic_group": "contact_info",
      "description": "Customer mobile phone number.",
      "validation": {"regex": "^1[3-9]\\d{9}$"},
      "enum": null,
      "default": null,
      "example": "13800138000"
    },
    "email": {
      "name": "email",
      "type": "string",
      "semantic_group": "contact_info",
      "description": "Customer email address.",
      "validation": {"regex": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"},
      "enum": null,
      "default": null,
      "example": "jordan.rivera@example.com"
    },
    "address": {
      "name": "address",
      "type": "string",
      "semantic_group": "contact_info",
      "description": "Customer mailing address.",
      "validation": {"regex": "^.{5,120}$"},
      "enum": null,
      "default": null,
      "example": "742 Evergreen Terrace, Springfield, IL 62704"
    },
    "fraud_report_id": {
      "name": "fraud_report_id",
      "type": "string",
      "semantic_group": "fraud_info",
      "description": "Ticket identifier for a filed fraud report.",
      "validation": {"regex": "^FR-\\d{8}$"},
      "enum": null,
      "default": null,
      "example": "FR-00481523"
    },
    "fraud_amount": {
      "name": "fraud_amount",
      "type": "float",
      "semantic_group": "fraud_info",
      "description": "Total disputed amount of the fraudulent transaction(s).",
      "validation": {"min": 0.0, "max": 1000000.0},
      "enum": null,
      "default": null,
      "example": 529.99
    },
    "dispute_status": {
      "name": "dispute_status",
      "type": "enum",
      "semantic_group": "fraud_info",
      "description": "Current resolution status of the fraud dispute.",
      "validation": {"enum": ["open", "under_review", "resolved", "rejected"]},
      "enum": ["open", "under_review", "resolved", "rejected"],
      "default": null,
      "example": "under_review"
    },
    "loan_amount": {
      "name": "loan_amount",
      "type": "float",
      "semantic_group": "loan_info",
      "description": "Requested principal loan amount.",
      "validation": {"min": 0.0, "max": 10000000.0},
      "enum": null,
      "default": null,
      "example": 25000.0
    },
    "loan_term": {
      "name": "loan_term",
      "type": "integer",
      "semantic_group": "loan_info",
      "description": "Requested loan repayment term in months.",
      "validation": {"min": 1, "max": 480},
      "enum": null,
      "default": null,
      "example": 36
    },
    "loan_purpose": {
      "name": "loan_purpose",
      "type": "string",
      "semantic_group": "loan_info",
      "description": "Stated purpose of the requested loan.",
      "validation": {"regex": "^.{2,120}$"},
      "enum": null,
      "default": null,
      "example": "home renovation"
    },
    "income": {
      "name": "income",
      "type": "integer",
      "semantic_group": "customer_profile",
      "description": "Customer self-reported annual income.",
      "validation": {"min": 0, "max": 100000000},
      "enum": null,
      "default": null,
      "example": 82000
    },
    "occupation": {
      "name": "occupation",
      "type": "string",
      "semantic_group": "customer_profile",
      "description": "Customer occupation / job title.",
      "validation": {"regex": "^.{2,60}$"},
      "enum": null,
      "default": null,
      "example": "software engineer"
    }
  }
}
